<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <!--
        # Собрать всё в правильном порядке
        .\mvnw install -DskipTests

        # Запустить demo-rest (REST + GraphQL + event publisher)
        .\mvnw spring-boot:run -pl demo-rest -am

        # Запустить audit-service (RabbitMQ consumer)
        .\mvnw spring-boot:run -pl audit-service -am

        # Запустить gRPC Analytics Server (порт gRPC: 9090, HTTP: 8083)
        .\mvnw spring-boot:run -pl grpc-analytics-server -am

        # Запустить gRPC Enrichment Client (RabbitMQ → gRPC → RabbitMQ, HTTP: 8082)
        .\mvnw spring-boot:run -pl grpc-enrichment-client -am

        # Запустить сервис уведомлений
        .\mvnw spring-boot:run -pl notification-service -DskipTests

        Далее в браузере http://localhost:8084/
    -->

    <groupId>edu.rutmiit.pochaev</groupId>
    <artifactId>demo-rest-root</artifactId>
    <version>1.0</version>
    <packaging>pom</packaging>
    <name>demo-rest [root aggregator]</name>

    <modules>
        <!-- Контракты (библиотеки без main) — собираются первыми -->
        <module>books-api-contract</module>
        <module>books-events-contract</module>
        <module>books-grpc-contract</module>

        <!-- Сервисы — зависят от контрактов -->
        <module>demo-rest</module>
        <module>audit-service</module>
        <module>grpc-analytics-server</module>
        <module>grpc-enrichment-client</module>
        <module>notification-service</module>
    </modules>

</project>
